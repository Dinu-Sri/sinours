# Sinours Watercolor — environment template.
# Copy to .env for local dev. In production, set these in the Portainer stack env UI.

# --- Database ---
# Compose sets DB_PASSWORD; the entrypoint assembles the full DATABASE_URL.
DB_PASSWORD=change-me-in-production

# --- App ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Cloudflare Tunnel (production only) ---
# CF_TUNNEL_TOKEN=
